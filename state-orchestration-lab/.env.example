# Copy to .env and fill (never commit .env)
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Optional — only if run_neo4j_probe shows different labels/properties
# NEO4J_FACT_LABEL=Fact
# NEO4J_KEY_PROPERTY=key
# NEO4J_BODY_PROPERTY=body
# NEO4J_VALID_FROM_PROPERTY=valid_from
# NEO4J_VALID_UNTIL_PROPERTY=valid_until
# NEO4J_INBOUND_REL_TYPES=DEPENDS_ON,USES,IMPLEMENTS
# NEO4J_EMBEDDING_PROPERTY=embedding

# Experiment C constraint replay (ontology axis): bound v for team size checks
